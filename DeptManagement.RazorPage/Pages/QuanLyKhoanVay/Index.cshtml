@page
@model DeptManagement.RazorPage.Pages.QuanLyKhoanVay.IndexModel
@{
    ViewData["Title"] = "Quản lý khoản vay";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Quản lý khoản vay</h2>
    <button type="button" class="btn btn-primary" id="btnAddKhoanNo">+ Thêm khoản nợ</button>
</div>

<div id="alertBox"></div>

<div class="card mb-4">
    <div class="card-header fw-semibold">Danh sách khoản nợ</div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th>Tên khoản nợ</th>
                        <th>Ghi chú</th>
                        <th class="text-end" style="width: 220px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="khoanNoTableBody">
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">Đang tải dữ liệu...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="card d-none" id="chiTietSection">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">Chi tiết khoản vay: <span id="selectedKhoanNoName" class="text-primary"></span></span>
        <button type="button" class="btn btn-sm btn-primary" id="btnAddChiTiet">+ Thêm chi tiết</button>
    </div>
    <div class="card-body">
        <div class="row g-3 mb-4" id="thongKeBox">
            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted small">Tổng tiền vay</div>
                    <div class="fs-5 fw-semibold" id="tongTienVay">0</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted small">Tổng tiền lãi</div>
                    <div class="fs-5 fw-semibold" id="tongTienLai">0</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="border rounded p-3 bg-light">
                    <div class="text-muted small">Tổng tiền phải trả</div>
                    <div class="fs-5 fw-semibold text-danger" id="tongTienPhaiTra">0</div>
                </div>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>ID</th>
                        <th>Ngày vay</th>
                        <th>Số tiền vay</th>
                        <th>Số tiền lãi</th>
                        <th>Số tiền trả/kỳ</th>
                        <th>Số ngày trả</th>
                        <th>Tổng tiền</th>
                        <th class="text-end" style="width: 140px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="chiTietTableBody">
                    <tr>
                        <td colspan="8" class="text-center text-muted py-3">Chọn khoản nợ để xem chi tiết</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="khoanNoModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="khoanNoModalTitle">Thêm khoản nợ</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="khoanNoId" value="0" />
                <div class="mb-3">
                    <label for="tenKhoanNo" class="form-label">Tên khoản nợ</label>
                    <input type="text" class="form-control" id="tenKhoanNo" required />
                </div>
                <div class="mb-3">
                    <label for="ghiChu" class="form-label">Ghi chú</label>
                    <textarea class="form-control" id="ghiChu" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnSaveKhoanNo">Lưu</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="chiTietModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="chiTietModalTitle">Thêm chi tiết khoản vay</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="chiTietId" value="0" />
                <input type="hidden" id="chiTietKhoanNoId" value="0" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="ngayVay" class="form-label">Ngày vay</label>
                        <input type="date" class="form-control" id="ngayVay" required />
                    </div>
                    <div class="col-md-6">
                        <label for="soTienVay" class="form-label">Số tiền vay</label>
                        <input type="number" class="form-control" id="soTienVay" min="0" step="1000" value="0" />
                    </div>
                    <div class="col-md-6">
                        <label for="soTienLai" class="form-label">Số tiền lãi</label>
                        <input type="number" class="form-control" id="soTienLai" min="0" step="1000" value="0" />
                    </div>
                    <div class="col-md-6">
                        <label for="soTienTraMoiKy" class="form-label">Số tiền trả mỗi kỳ</label>
                        <input type="number" class="form-control" id="soTienTraMoiKy" min="0" step="1000" value="0" />
                    </div>
                    <div class="col-md-6">
                        <label for="soNgayTra" class="form-label">Số ngày trả</label>
                        <input type="number" class="form-control" id="soNgayTra" min="0" value="0" />
                    </div>
                    <div class="col-md-6">
                        <label for="tongTien" class="form-label">Tổng tiền</label>
                        <input type="number" class="form-control" id="tongTien" min="0" step="1000" value="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="btnSaveChiTiet">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const API_BASE = '@Model.ApiBaseUrl';
        const KHOAN_NO_URL = `${API_BASE}/QuanLiKhoanNo`;
        const CHI_TIET_URL = `${API_BASE}/ChiTietKhoanVay`;

        let khoanNoList = [];
        let selectedKhoanNoId = 0;
        let chiTietList = [];

        const khoanNoModal = new bootstrap.Modal(document.getElementById('khoanNoModal'));
        const chiTietModal = new bootstrap.Modal(document.getElementById('chiTietModal'));

        function showAlert(message, type = 'success') {
            document.getElementById('alertBox').innerHTML =
                `<div class="alert alert-${type} alert-dismissible fade show" role="alert">
                    ${message}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>`;
        }

        function formatMoney(value) {
            return Number(value || 0).toLocaleString('vi-VN');
        }

        async function loadKhoanNo() {
            const tbody = document.getElementById('khoanNoTableBody');
            try {
                const response = await fetch(KHOAN_NO_URL);
                if (!response.ok) throw new Error('Không thể tải danh sách khoản nợ');
                khoanNoList = await response.json();

                if (!khoanNoList.length) {
                    tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-4">Chưa có khoản nợ nào</td></tr>';
                    return;
                }

                tbody.innerHTML = khoanNoList.map(item => `
                    <tr class="${selectedKhoanNoId === item.id ? 'table-primary' : ''}">
                        <td>${item.id}</td>
                        <td>${item.tenKhoanNo}</td>
                        <td>${item.ghiChu || '-'}</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-info me-1" onclick="viewChiTiet(${item.id}, '${item.tenKhoanNo.replace(/'/g, "\\'")}')">Chi tiết</button>
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditKhoanNo(${item.id})">Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteKhoanNo(${item.id})">Xóa</button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                tbody.innerHTML = `<tr><td colspan="4" class="text-center text-danger py-4">${error.message}</td></tr>`;
            }
        }

        function resetKhoanNoForm() {
            document.getElementById('khoanNoId').value = '0';
            document.getElementById('tenKhoanNo').value = '';
            document.getElementById('ghiChu').value = '';
            document.getElementById('khoanNoModalTitle').textContent = 'Thêm khoản nợ';
        }

        document.getElementById('btnAddKhoanNo').addEventListener('click', () => {
            resetKhoanNoForm();
            khoanNoModal.show();
        });

        function openEditKhoanNo(id) {
            const item = khoanNoList.find(x => x.id === id);
            if (!item) return;

            document.getElementById('khoanNoId').value = item.id;
            document.getElementById('tenKhoanNo').value = item.tenKhoanNo;
            document.getElementById('ghiChu').value = item.ghiChu || '';
            document.getElementById('khoanNoModalTitle').textContent = 'Sửa khoản nợ';
            khoanNoModal.show();
        }

        document.getElementById('btnSaveKhoanNo').addEventListener('click', async () => {
            const id = parseInt(document.getElementById('khoanNoId').value, 10);
            const tenKhoanNo = document.getElementById('tenKhoanNo').value.trim();
            if (!tenKhoanNo) {
                showAlert('Vui lòng nhập tên khoản nợ', 'warning');
                return;
            }

            const payload = {
                id: id,
                tenKhoanNo: tenKhoanNo,
                ghiChu: document.getElementById('ghiChu').value.trim()
            };

            const isEdit = id > 0;
            try {
                const response = await fetch(KHOAN_NO_URL, {
                    method: isEdit ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) throw new Error('Lưu khoản nợ thất bại');

                khoanNoModal.hide();
                showAlert(isEdit ? 'Cập nhật khoản nợ thành công' : 'Thêm khoản nợ thành công');
                await loadKhoanNo();
            } catch (error) {
                showAlert(error.message, 'danger');
            }
        });

        async function deleteKhoanNo(id) {
            if (!confirm('Bạn có chắc muốn xóa khoản nợ này?')) return;

            try {
                const response = await fetch(`${KHOAN_NO_URL}/${id}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Xóa khoản nợ thất bại');

                if (selectedKhoanNoId === id) {
                    selectedKhoanNoId = 0;
                    document.getElementById('chiTietSection').classList.add('d-none');
                }

                showAlert('Xóa khoản nợ thành công');
                await loadKhoanNo();
            } catch (error) {
                showAlert(error.message, 'danger');
            }
        }

        async function loadThongKe(khoanNoId) {
            try {
                const response = await fetch(`${CHI_TIET_URL}/ThongKe/${khoanNoId}`);
                if (!response.ok) throw new Error('Không thể tải thống kê');
                const stats = await response.json();

                document.getElementById('tongTienVay').textContent = formatMoney(stats.tongTienVay);
                document.getElementById('tongTienLai').textContent = formatMoney(stats.tongTienLai);
                document.getElementById('tongTienPhaiTra').textContent = formatMoney(stats.tongTienPhaiTra);
            } catch (error) {
                showAlert(error.message, 'danger');
            }
        }

        async function loadChiTiet(khoanNoId) {
            const tbody = document.getElementById('chiTietTableBody');
            try {
                const response = await fetch(`${CHI_TIET_URL}/KhoanNo/${khoanNoId}`);
                if (!response.ok) throw new Error('Không thể tải chi tiết khoản vay');
                chiTietList = await response.json();

                if (!chiTietList.length) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">Chưa có chi tiết khoản vay</td></tr>';
                    return;
                }

                tbody.innerHTML = chiTietList.map(item => `
                    <tr>
                        <td>${item.id}</td>
                        <td>${item.ngayVay}</td>
                        <td>${formatMoney(item.soTienVay)}</td>
                        <td>${formatMoney(item.soTienLai)}</td>
                        <td>${formatMoney(item.soTienTraMoiKy)}</td>
                        <td>${item.soNgayTra ?? '-'}</td>
                        <td>${formatMoney(item.tongTien)}</td>
                        <td class="text-end">
                            <button class="btn btn-sm btn-outline-primary me-1" onclick="openEditChiTiet(${item.id})">Sửa</button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteChiTiet(${item.id})">Xóa</button>
                        </td>
                    </tr>
                `).join('');
            } catch (error) {
                tbody.innerHTML = `<tr><td colspan="8" class="text-center text-danger py-3">${error.message}</td></tr>`;
            }
        }

        async function viewChiTiet(khoanNoId, tenKhoanNo) {
            selectedKhoanNoId = khoanNoId;
            document.getElementById('selectedKhoanNoName').textContent = tenKhoanNo;
            document.getElementById('chiTietSection').classList.remove('d-none');
            await loadKhoanNo();
            await loadThongKe(khoanNoId);
            await loadChiTiet(khoanNoId);
        }

        function resetChiTietForm() {
            document.getElementById('chiTietId').value = '0';
            document.getElementById('chiTietKhoanNoId').value = selectedKhoanNoId;
            document.getElementById('ngayVay').value = new Date().toISOString().split('T')[0];
            document.getElementById('soTienVay').value = '0';
            document.getElementById('soTienLai').value = '0';
            document.getElementById('soTienTraMoiKy').value = '0';
            document.getElementById('soNgayTra').value = '0';
            document.getElementById('tongTien').value = '0';
            document.getElementById('chiTietModalTitle').textContent = 'Thêm chi tiết khoản vay';
        }

        document.getElementById('btnAddChiTiet').addEventListener('click', () => {
            if (!selectedKhoanNoId) {
                showAlert('Vui lòng chọn khoản nợ trước', 'warning');
                return;
            }
            resetChiTietForm();
            chiTietModal.show();
        });

        function openEditChiTiet(id) {
            const item = chiTietList.find(x => x.id === id);
            if (!item) return;

            document.getElementById('chiTietId').value = item.id;
            document.getElementById('chiTietKhoanNoId').value = item.khoanNoId;
            document.getElementById('ngayVay').value = item.ngayVay;
            document.getElementById('soTienVay').value = item.soTienVay;
            document.getElementById('soTienLai').value = item.soTienLai;
            document.getElementById('soTienTraMoiKy').value = item.soTienTraMoiKy || 0;
            document.getElementById('soNgayTra').value = item.soNgayTra || 0;
            document.getElementById('tongTien').value = item.tongTien || 0;
            document.getElementById('chiTietModalTitle').textContent = 'Sửa chi tiết khoản vay';
            chiTietModal.show();
        }

        document.getElementById('btnSaveChiTiet').addEventListener('click', async () => {
            const id = parseInt(document.getElementById('chiTietId').value, 10);
            const khoanNoId = parseInt(document.getElementById('chiTietKhoanNoId').value, 10);
            const ngayVay = document.getElementById('ngayVay').value;

            if (!ngayVay) {
                showAlert('Vui lòng chọn ngày vay', 'warning');
                return;
            }

            const payload = {
                id: id,
                khoanNoId: khoanNoId,
                ngayVay: ngayVay,
                soTienVay: parseFloat(document.getElementById('soTienVay').value) || 0,
                soTienLai: parseFloat(document.getElementById('soTienLai').value) || 0,
                soTienTraMoiKy: parseFloat(document.getElementById('soTienTraMoiKy').value) || 0,
                soNgayTra: parseInt(document.getElementById('soNgayTra').value, 10) || 0,
                tongTien: parseFloat(document.getElementById('tongTien').value) || 0
            };

            const isEdit = id > 0;
            try {
                const response = await fetch(CHI_TIET_URL, {
                    method: isEdit ? 'PUT' : 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });

                if (!response.ok) throw new Error('Lưu chi tiết thất bại');

                chiTietModal.hide();
                showAlert(isEdit ? 'Cập nhật chi tiết thành công' : 'Thêm chi tiết thành công');
                await loadThongKe(khoanNoId);
                await loadChiTiet(khoanNoId);
            } catch (error) {
                showAlert(error.message, 'danger');
            }
        });

        async function deleteChiTiet(id) {
            if (!confirm('Bạn có chắc muốn xóa chi tiết này?')) return;

            try {
                const response = await fetch(`${CHI_TIET_URL}/${id}`, { method: 'DELETE' });
                if (!response.ok) throw new Error('Xóa chi tiết thất bại');

                showAlert('Xóa chi tiết thành công');
                await loadThongKe(selectedKhoanNoId);
                await loadChiTiet(selectedKhoanNoId);
            } catch (error) {
                showAlert(error.message, 'danger');
            }
        }

        loadKhoanNo();
    </script>
}
